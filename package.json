{
  "name": "@enonic/lib-admin-ui",
  "version": "6.1.0",
  "description": "Admin UI Library",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/enonic/lib-admin-ui"
  },
  "scripts": {
    "build": "pnpm run build:dev",
    "build:prod": "pnpm run /^build:prod:.*$/",
    "build:prod:js": "tsc -b",
    "build:prod:lib": "cross-env BUILD_TARGET=js vite build --mode production",
    "build:prod:css": "cross-env BUILD_TARGET=css vite build --mode production",
    "build:dev": "pnpm run /^build:dev:.*$/",
    "build:dev:lib": "cross-env BUILD_TARGET=js vite build --mode development",
    "build:dev:css": "cross-env BUILD_TARGET=css vite build --mode development",
    "build:dev:js": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run fix && pnpm run check:types && pnpm run test",
    "check:lint": "biome check .",
    "check:types": "tsc -b && tsc -p tsconfig.test.json",
    "fix": "biome check . --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "dompurify": "~3.4.11",
    "fine-uploader": "^5.16.2",
    "jquery": "~3.7.1",
    "jquery-simulate": "^1.0.2",
    "jquery-ui": "^1.14.2",
    "mousetrap": "^1.6.5",
    "nanoid": "~5.1.11",
    "nanostores": "~1.3.0",
    "q": "^1.5.1"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@enonic/ui": "^1.0.1",
    "@radix-ui/react-slot": "^1.2.0",
    "focus-trap-react": "^11.0.0",
    "lucide-react": ">=0.500.0",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@enonic/ui": "^1.0.4",
    "@rollup/plugin-inject": "^5.0.5",
    "@storybook/addon-docs": "~10.4.2",
    "@storybook/addon-themes": "~10.4.2",
    "@storybook/preact-vite": "~10.4.2",
    "@tailwindcss/vite": "~4.3.0",
    "@types/jquery": "^3.5.33",
    "@types/jqueryui": "^1.12.24",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "~25.9.2",
    "@types/q": "^1.5.8",
    "autoprefixer": "^10.5.0",
    "browserslist-config-enonic": "^1.0.8",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.2",
    "enonic-admin-artifacts": "^2.5.0",
    "husky": "^9.1.7",
    "jiti": "~2.7.0",
    "less": "^4.6.4",
    "lucide-react": "^1.17.0",
    "postcss-normalize": "^13.0.1",
    "postcss-sort-media-queries": "^6.6.1",
    "preact": "^10.29.2",
    "storybook": "~10.4.2",
    "tailwindcss": "~4.3.0",
    "tw-animate-css": "~1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "~4.1.8"
  },
  "browserslist": [
    "extends browserslist-config-enonic"
  ],
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">= 24.15.0",
    "pnpm": ">= 10.33.4"
  }
}
